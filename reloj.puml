@startuml Clock Service
set separator none
hide empty members

package "reloj.h" {
    
    class clock_t {
        - time
        - alarm
        - ticks_count
        - ticks_per_second
        - time_is_valid
        - alarm_enabled
        - AlarmHandler
        + Create()
        + GetCurrentTime()
        + SetupCurrentTime()
        + NewTick()
        + SetupAlarm()
        + GetAlarm()
        + ToggleAlarm()
    }

    interface clock_event_t
    clock_t o--> clock_event_t

}
@enduml
